# Server
PORT=3000
NODE_ENV=development

# Database — غيّر الـ dialect وبيانات الاتصال لو غيّرت الـ DB
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=manga_db
DB_USER=root
DB_PASS=yourpassword

# Admin — الـ key اللي هتبعته في X-Admin-Key header
ADMIN_API_KEY=change_this_to_a_strong_secret

# Storage — خيارات: 'local' (لتخزين الملفات محلياً على جهازك) أو 'supabase'
STORAGE_PROVIDER=supabase

# Supabase Storage (مطلوب فقط لو STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key
SUPABASE_BUCKET=manga-images

# Frontend URL (للـ CORS)
FRONTEND_URL=http://localhost:5173

